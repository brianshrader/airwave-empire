# Copy to .env and fill in. Never commit .env.
#
# Production: `.env` is not in git. If your deploy replaces the app directory (git pull, rsync,
# unzip), a server-only `.env` in that tree can disappear. Prefer: set CLERK_SECRET_KEY (and other
# secrets) in the host environment, or keep one file outside the deploy path and set on the host:
#   WL_ENV_FILE=/var/www/yourapp/secrets.env
# (server.js loads `.env` first, then merges WL_ENV_FILE with override.)

# ── Clerk (accounts) — https://dashboard.clerk.com
# Optional: PEM public key from Clerk Dashboard → JWT template / API keys (“Show JWT public key”) for
# networkless verify. Usually leave unset and use CLERK_SECRET_KEY only.
# CLERK_JWT_KEY=
# If verify returns 401 “Invalid JWT Authorized party (azp)”, allowlist SPA origins Clerk issues tokens for:
# CLERK_AUTHORIZED_PARTIES=https://www.airwaveempire.com,https://airwaveempire.com
# Production (NODE_ENV=production): CLERK_SECRET_KEY is REQUIRED or the server will not start.
# Local dev without Clerk: set WL_ALLOW_MP_AUTH_BYPASS=1 so Socket.io can run without JWT (never use in production).
# If CLERK_SECRET_KEY is set, multiplayer uses signed-in verification (WL_ALLOW_MP_AUTH_BYPASS is ignored).
CLERK_SECRET_KEY=
# Optional: merge Clerk Dashboard Billing into plan resolution (GET …/users/{id}/billing/subscription). Default off — use Stripe + accountStore only. Enable only if Clerk Billing is on for this instance.
# WL_USE_CLERK_BILLING=1
# WL_ALLOW_MP_AUTH_BYPASS=1
# PostHog browser analytics (optional — product funnel). Public project API key only.
# VITE_POSTHOG_API_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Frontend (Vite): copy to .env — only VITE_* vars are exposed to the browser bundle.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Launch: use a key whose Frontend API host is Clerk’s default (*.clerk.accounts…). If the browser calls a
# custom domain (e.g. clerk.yourbrand.com) and fails, remove the custom Frontend API / proxy in Clerk
# Dashboard, rotate to a fresh publishable key, rebuild, redeploy. Do not set proxy vars until verified:
# Optional verified proxy only (omit at launch): VITE_CLERK_PROXY_URL=https://verified-proxy.example/clerk
# Optional: require sign-in when play.html has no wl-require-clerk meta (rare). Meta content="1" always gates solo; it is NOT disabled by VITE_REQUIRE_CLERK=false (avoids accidental unlock if a local .env is used on the server build).
# VITE_REQUIRE_CLERK=true
# play.html <meta wl-require-clerk>: Vite injects this at dev/build (default dev=0, production build=1). Override:
# VITE_WL_REQUIRE_CLERK_META=0
# VITE_WL_REQUIRE_CLERK_META=1
# With npm run client:dev, Vite injects wl-require-clerk=0; src/main.js treats meta=0 as “no gate” even if VITE_REQUIRE_CLERK=true in .env.local.
# Public URL of your Node game server (Socket.io + /api/*). Required when static hosting (e.g. Amplify)
# is not the same origin as the API (Lightsail): home/account billing calls must reach Node. No trailing slash.
# Also injected into dist/play.html meta + MP “server address” default on production build (see vite.config.js).
# VITE_GAME_SERVER_URL=https://api.airwaveempire.com
# Alternative: empty VITE_GAME_SERVER_URL but set <meta name="wl-game-server-url" content="..."> in play.html before build.
# After changing VITE_*, run:  npm run build

# Account + marketing — optional overrides for plan button labels (defaults in src/billingPriceLabels.js).
# VITE_ACCOUNT_PRICE_STARTER_MONTHLY=$4.99/mo
# VITE_ACCOUNT_PRICE_STARTER_ANNUAL=$49.99/yr
# VITE_ACCOUNT_PRICE_PRO_MONTHLY=$9.99/mo
# VITE_ACCOUNT_PRICE_PRO_ANNUAL=$79.99/yr
# Local: open http://localhost:3000 after build, or  npm run client:dev  →  http://localhost:5173
# Trade “ratings digest” (📰 DIGEST in play UI): POST /api/ratings-digest needs the Node server (SHORTAPI_KEY and/or OPENROUTER_API_KEY and/or OPENAI_API_KEY). Vite dev proxies /api → :3000 (vite.config.js).

# Express JSON body limit (cloud uploads, large API bodies). Default 32mb. If nginx proxies, set client_max_body_size to match.
# JSON_BODY_LIMIT=32mb
# Cloud saves (solo) — max JSON size per save; default 12 MiB, cap 24 MiB. Restart server after changing.
# CLOUD_SAVE_MAX_BYTES=12582912
# CLOUD_SAVE_MAX_SLOTS=10

# Generated assets GC (logos, remote vans, jingles, portraits — not library/). Pins paths found in saves/*.json,
# data/cloud_saves/**, multiplayer/saves/*.json. The running server does not GC — schedule on the host (see scripts/gc-generated-assets.cron.example).
# Unreferenced files older than TTL (mtime) are deleted; files referenced in scanned JSON are kept.
# Production-style TTL (orphans only): 30 days
# GENERATED_ASSET_TTL_DAYS=30
# Do not delete files newer than this (grace before first delete). Default 7.
# GENERATED_ASSET_MIN_AGE_DAYS=7
# Set to 1 to only log what would be deleted (recommended before first real run on Lightsail).
# GENERATED_ASSET_GC_DRY_RUN=1
# Optional comma-separated extra dirs to scan for /generated-*/ URL references (recursive .json).
# GENERATED_PIN_EXTRA_JSON_DIRS=

# Beta feedback — FormSubmit inbox (match FEEDBACK_TO). Set VITE_* so the browser POSTs to FormSubmit (server/VPS gets HTTP 403 from Cloudflare otherwise).
# VITE_FEEDBACK_FORMSUBMIT_EMAIL=airwaveempire@gmail.com
# Server-only fallback POST /api/feedback (often blocked from datacenters). Same inbox as above.
# FEEDBACK_TO=airwaveempire@gmail.com
# When the user leaves email blank, FormSubmit still needs a valid-looking address (not .local). Override if needed:
# FEEDBACK_ANONYMOUS_EMAIL=anonymous@airwaveempire.com

# ── AI images (logos + portraits) — server only; never expose to the browser
# ShortAPI (default if SHORTAPI_KEY is set): https://shortapi.ai/console/keys/
# Used for AI logos and portraits when Grok is not used for that request.
SHORTAPI_KEY=
# Optional: override model slug (default shortapi/z-image/text-to-image)
# SHORTAPI_IMAGE_MODEL=shortapi/z-image/text-to-image
# ShortAPI z-image only allows: 1K or 1.5K (exact strings; default 1K)
# SHORTAPI_RESOLUTION=1K
# SHORTAPI_RESOLUTION=1.5K
# Suno v5.5 station jingles (Brand modal → “Station jingle”): same SHORTAPI_KEY, POST /api/generate-station-jingle
# Docs: https://shortapi.ai/models/suno/suno-v5.5/generate/
# SHORTAPI_SUNO_MODEL=suno/suno-v5.5/generate
# SHORTAPI_SUNO_POLL_MAX_MS=300000
# JINGLE_MAX_PER_HOUR=40
# Grok / xAI — logos if ShortAPI unset.
GROK_API_KEY=
# shortapi | grok | auto — auto picks ShortAPI when SHORTAPI_KEY is set
IMAGE_GEN_PROVIDER=auto
# Trade-press ratings digest (text) — https://openrouter.ai/keys
# Recommended: set OPENROUTER_API_KEY and leave RATINGS_DIGEST_PROVIDER unset (auto). Auto uses OpenRouter first; it does not fall back to
# ShortAPI for digest after OpenRouter fails (ShortAPI often returns bogus "invalid model" for every chat slug). Use OpenAI as second key if needed.
# Optional: RATINGS_DIGEST_FALLBACK_SHORTAPI=1 to allow ShortAPI digest after an OpenRouter error (rare).
# Or force digest to OpenRouter only: RATINGS_DIGEST_PROVIDER=openrouter
# RATINGS_DIGEST_PROVIDER=auto|shortapi|openrouter|openai
# ShortAPI LLM (optional; same key as images) — often “invalid model” if your key has no chat queue access.
# SHORTAPI_DIGEST_MODEL=openai/gpt-5.4-mini/chat
OPENROUTER_API_KEY=
# Model slug from https://openrouter.ai/models — not the same as ShortAPI (no …/chat).
# OpenRouter uses ":free" on some models for the free tier (e.g. google/gemma-4-26b-a4b-it:free). If your loader chokes on ":",
# quote the value: OPENROUTER_DIGEST_MODEL="google/gemma-4-26b-a4b-it:free"
# OPENROUTER_DIGEST_MODEL=openai/gpt-4o-mini
# Optional; OpenRouter recommends these for rankings / support
# OPENROUTER_HTTP_REFERER=https://airwaveempire.com
# OPENROUTER_APP_TITLE=Airwave Empire
# OpenAI direct (optional last resort in auto)
OPENAI_API_KEY=
# OPENAI_DIGEST_MODEL=gpt-4o-mini
# Digest rate limit per client IP (rolling 1h). Default 120. Use 0 for unlimited (local dev only).
# RATINGS_DIGEST_MAX_PER_HOUR=120
# SHORTAPI_DIGEST_MAX_TOKENS=900
# SHORTAPI_DIGEST_TEMPERATURE=0.65

# ── Stripe (payments) — https://dashboard.stripe.com
# Vite client: which Price IDs to send to checkout (must match STRIPE_SECRET_KEY mode).
# Omit or "test" → test dashboard prices; "live" / "production" → live prices.
# Production builds default to live unless you set VITE_STRIPE_PRICE_MODE=test (e.g. staging).
# VITE_STRIPE_PRICE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price from Stripe Dashboard → Products (or use request body priceId)
STRIPE_PRICE_ID=
# payment | subscription — default is payment
STRIPE_CHECKOUT_MODE=payment

# Public URL of your game (for Checkout success/cancel redirects)
PUBLIC_APP_URL=http://localhost:3000

# Extra browser origins allowed for CORS (HTTP API + Socket.io), comma-separated.
# Use for Amplify previews, alternate domains, etc. Production defaults include
# https://airwaveempire.com and https://www.airwaveempire.com plus common localhost ports.
# CORS_ORIGINS=https://main.d123abc.amplifyapp.com
