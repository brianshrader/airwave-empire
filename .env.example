# Copy to .env and fill in. Never commit .env.

# ── Clerk (accounts) — https://dashboard.clerk.com
# Leave unset for local dev: multiplayer works without sign-in.
# Set both to require signed-in players for Socket.io (production).
CLERK_SECRET_KEY=
# Frontend (Vite): copy to .env — exposed to client as import.meta.env.VITE_CLERK_PUBLISHABLE_KEY
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# After setting this, run:  npm run build
# Then open http://localhost:3000 — Node serves dist/ so Clerk loads. (Raw source index.html cannot load @clerk/clerk-js without Vite.)
# For hot reload without rebuilding:  npm run client:dev  →  http://localhost:5173

# ── Stripe (payments) — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price from Stripe Dashboard → Products (or use request body priceId)
STRIPE_PRICE_ID=
# payment | subscription — default is payment
STRIPE_CHECKOUT_MODE=payment

# Public URL of your game (for Checkout success/cancel redirects)
PUBLIC_APP_URL=http://localhost:3000
