{
  "name": "airwave-empire",
  "version": "1.0.0",
  "description": "Airwave Empire — multiplayer radio management game server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "client:dev": "vite",
    "build": "vite build",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:logs": "pm2 logs airwave-empire",
    "preview": "vite preview",
    "inspect:shares": "npm run build && node scripts/inspect-share-calibration.mjs",
    "sim:public-radio": "npm run build && node scripts/sim-public-radio.mjs",
    "sim:public-radio:full": "npm run build && node scripts/run-public-radio-full.mjs",
    "sim:market-health": "npm run build && node scripts/sim-market-health.mjs",
    "sim:ecology-deep": "npm run build && node scripts/run-ecology-diagnostic.mjs",
    "audit:am": "node scripts/audit-am-stations.mjs",
    "test:solo-reentry": "node scripts/test-solo-reentry.mjs",
    "dedupe:portraits": "node scripts/dedupe-portrait-library.mjs",
    "sort:portraits": "node scripts/sort-portraits-into-library.mjs",
    "gen:portraits:batch": "node scripts/batch-generate-portrait-library.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@clerk/clerk-js": "^6.3.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.2",
    "stripe": "^17.5.0"
  }
}
